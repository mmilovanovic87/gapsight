  "cross_metric_rules": [
    {
      "id": "accuracy_fairness_tradeoff",
      "severity": "WARNING",
      "conditions": {
        "accuracy": { "gte": 0.90 },
        "demographic_parity_diff": { "gte": 0.15 }
      },
      "message": "High accuracy with significant fairness gap detected. EU AI Act Article 10 and NIST MEASURE 2.11 require explicit analysis and documentation of this tradeoff."
    },
    {
      "id": "robustness_without_monitoring",
      "severity": "WARNING",
      "conditions": {
        "adversarial_robustness_score": { "gte": 0.80 },
        "drift_monitoring_active": { "eq": false }
      },
      "message": "Robustness measured during development does not guarantee runtime robustness without active production monitoring."
    },
    {
      "id": "high_drift_without_retraining",
      "severity": "CRITICAL",
      "conditions": {
        "data_drift_score": { "gte": 0.20 },
        "months_since_retrain": { "gte": 12 }
      },
      "message": "High drift score combined with stale model requires immediate retraining plan."
    },
    {
      "id": "fairness_without_mitigation",
      "severity": "CRITICAL",
      "conditions": {
        "equalized_odds_diff": { "gte": 0.10 },
        "bias_mitigation_applied": { "eq": false }
      },
      "message": "Bias detected without applied mitigation. Direct EU AI Act Article 10 violation."
    },
    {
      "id": "explainability_oversight_gap",
      "severity": "WARNING",
      "conditions": {
        "explainability_method": { "eq": "None" },
        "human_oversight_weighted_score": { "lt": 0.80 }
      },
